rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation helpers
    function isValidVoter(data) {
      return data.tenantId is string &&
             data.schoolId is string &&
             data.hasVoted is bool &&
             data.isAuthorized is bool;
    }
    function isValidCandidate(data) {
      return data.tenantId is string &&
             data.name is string &&
             data.schoolId is string &&
             data.position is string;
    }
    function isValidBallot(data) {
      return data.tenantId is string &&
             data.candidateId is string &&
             data.schoolId is string &&
             data.timestamp == request.time;
    }

    match /{document=**} {
      allow read, write: if false; // Default deny
    }

    match /voters/{email} {
      allow read: if isSignedIn() && request.auth.token.email == email;
      allow update: if isSignedIn() && request.auth.token.email == email &&
                       isValidVoter(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['hasVoted']) &&
                       existing().hasVoted == false &&
                       incoming().hasVoted == true &&
                       incoming().tenantId == existing().tenantId;
    }

    match /candidates/{candidateId} {
      allow read: if isSignedIn() && resource.data.tenantId == get(/databases/$(database)/documents/voters/$(request.auth.token.email)).data.tenantId;
    }

    match /ballots/{ballotId} {
      allow create: if isSignedIn() &&
                       isValidBallot(incoming()) &&
                       incoming().tenantId == get(/databases/$(database)/documents/voters/$(request.auth.token.email)).data.tenantId &&
                       get(/databases/$(database)/documents/voters/$(request.auth.token.email)).data.hasVoted == false &&
                       existsAfter(/databases/$(database)/documents/voters/$(request.auth.token.email));
    }
  }
}
